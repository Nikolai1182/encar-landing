# Copy to `.env.local` for local development (see README).

# Секрет для защиты `/api/update-cars` (Authorization: Bearer …) — cron и ручной curl.
# На Vercel: Project → Settings → Environment Variables — то же значение для нужных окружений.
# Рекомендуется ≥ 32 символов; минимум 16 (проверка в API). Без секрета кнопка на сайте всё равно работает (server action).
CRON_SECRET=encar_2026_cron_v1_8HxK2mNp9qR4vXy1wZ3cL6jHgTfDsAuB0nMqW7xYz

# Отключить кнопку «Обновить данные» в production (останутся только cron / curl с секретом):
# ENABLE_PUBLIC_CATALOG_REFRESH=false
# ENABLE_PUBLIC_CATALOG_REFRESH=true

# Парсер Encar (опционально)
# ENCAR_SCRAPER_URL=https://www.encar.com/dc/dc_carsearchlist.do
# ENCAR_SCRAPER_NAV_TIMEOUT_MS=90000
# ENCAR_SCRAPER_NETWORKIDLE_MS=45000
# ENCAR_SCRAPER_MAX_CARS=40
# ENCAR_SCRAPER_SCROLL_STEPS=6
# ENCAR_SCRAPER_EXTRA_WAIT_MS_MIN=5000
# ENCAR_SCRAPER_EXTRA_WAIT_MS_MAX=8000
# ENCAR_SCRAPER_DEBUG=1
# ENCAR_SCRAPER_HEADLESS=false
# ENCAR_KRW_PER_USD=1350

# NEXT_PUBLIC_APP_URL=http://localhost:3000
